# Copy this file to .env and fill in the values.
# On Vercel: add each variable under Project → Settings → Environment Variables.

# Firebase web API key (Firebase Console → Project settings → General → Your apps → Web app → apiKey)
GOOGLE_API_KEY=""

# Public VAPID key for FCM web push (Firebase Console → Project settings → Cloud Messaging → Web Push certificates)
VITE_FIREBASE_VAPID_KEY=""

# Firebase Admin service account key as single-line JSON (Firebase Console → Project settings → Service accounts → Generate new private key)
# SERVER ONLY — keep secret.
FIREBASE_SERVICE_ACCOUNT=''
